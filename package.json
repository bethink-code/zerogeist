{
  "name": "zerogeist",
  "version": "1.0.0",
  "description": "A platform that builds and maintains a digital proxy for a person, sensing South Africa's emotional weather daily",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,vite -c blue,green \"cross-env NODE_ENV=development npx tsx server/index.ts\" \"npx vite --config vite.config.ts\"",
    "build": "vite build",
    "build:api": "esbuild server/api.ts --platform=node --packages=external --bundle --format=esm --outfile=api/index.mjs",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
